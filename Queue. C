from multiprocessing import Process, Queue

def sender(q1, q2):
    msg = "hello world"
    print("[parent] Sending to child:", msg)
    q1.put(msg)

    newmsg = q2.get()
    print("[parent] Received from child:", newmsg)

def receiver(q1, q2):
    msg = q1.get()
    print("[child] Received from parent:", msg)

    newmsg = "Hi"
    q2.put(newmsg)

if __name__ == "__main__":
    q1 = Queue()
    q2 = Queue()

    p1 = Process(target=sender, args=(q1, q2))
    p2 = Process(target=receiver, args=(q1, q2))

    p1.start()
    p2.start()

    p1.join()
    p2.join()
